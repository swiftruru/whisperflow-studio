{
  "name": "whisperflow-studio",
  "productName": "WhisperFlow Studio",
  "version": "1.16.4",
  "description": "WhisperFlow Studio - self-contained faster-whisper desktop transcription app",
  "main": "src/main/main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE='' electron .",
    "dev": "ELECTRON_RUN_AS_NODE='' electron .",
    "postinstall": "node scripts/postinstall.js",
    "clean": "node scripts/clean-dist.js",
    "i18n:lint": "node scripts/i18n-lint.js",
    "prebuild:mac": "node scripts/clean-dist.js && node scripts/i18n-lint.js",
    "prebuild:win": "node scripts/clean-dist.js && node scripts/i18n-lint.js",
    "prebuild:linux": "node scripts/clean-dist.js && node scripts/i18n-lint.js",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "test:e2e": "playwright test --config=e2e/playwright.config.js",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.js --ui",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.4",
    "strip-ansi": "6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "author": "ruru",
  "license": "MIT"
}
