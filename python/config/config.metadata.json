{
  "settingsUi": {
    "enumOptions": {
      "model": ["tiny", "base", "small", "medium", "large-v1", "large-v2", "large-v3"],
      "language": ["Chinese", "Japanese", "English", "Korean", "French", "German", "Spanish", "Italian", "Portuguese", "Russian", "Arabic", "Hindi"],
      "vad": ["none", "silero-vad", "silero-vad-expand-into-gaps", "silero-vad-skip-gaps", "periodic-vad"],
      "initial_prompt_mode": ["prepend_all_segments", "prepend_first_segment", "json_prompt_mode"],
      "device": ["auto", "cpu", "cuda"],
      "compute_type": ["auto", "float16", "float32", "int8", "int8_float16", "int8_float32"],
      "task": ["transcribe", "translate"],
      "overwrite_policy": ["overwrite", "skip", "rename-suffix"],
      "uiLanguage": ["auto", "zh-TW", "en"]
    },
    "languagePrompts": {
      "Chinese": "台灣繁體中文",
      "Japanese": "ワールドチャンピオンシップ",
      "English": "Hello. The following is an English transcript.",
      "Korean": "안녕하세요.",
      "French": "Bonjour.",
      "German": "Hallo.",
      "Spanish": "Hola.",
      "Italian": "Ciao.",
      "Portuguese": "Olá.",
      "Russian": "Здравствуйте.",
      "Arabic": "مرحباً.",
      "Hindi": "नमस्ते।"
    },
    "pathFieldKeys": {
      "folder": ["models_dir", "media_root_path", "media_file_path", "output_dir"],
      "file": ["media_file_name", "pythonPath"]
    },
    "hiddenFieldKeys": [
      "media_file_path",
      "media_file_name",
      "missing_count"
    ],
    "fieldGroups": [
      {
        "id": "general",
        "segment": "app",
        "keys": ["pythonPath", "media_root_path", "models_dir"]
      },
      {
        "id": "model",
        "segment": "transcription",
        "keys": ["model", "device", "compute_type"]
      },
      {
        "id": "transcription",
        "segment": "transcription",
        "keys": ["language", "task", "initial_prompt", "initial_prompt_mode"]
      },
      {
        "id": "output",
        "segment": "transcription",
        "keys": ["write_srt", "write_vtt", "write_txt", "write_json", "output_dir", "max_line_width", "overwrite_policy"]
      },
      {
        "id": "vad",
        "segment": "transcription",
        "keys": ["vad", "vad_merge_window", "vad_max_merge_size", "vad_padding", "vad_prompt_window"]
      },
      {
        "id": "advanced",
        "segment": "transcription",
        "defaultCollapsed": true,
        "keys": ["beam_size", "best_of", "temperature", "condition_on_previous_text", "no_speech_threshold", "logprob_threshold", "compression_ratio_threshold"]
      }
    ]
  },
  "appRuntime": {
    "windowDefaults": {
      "width": 1100,
      "height": 720,
      "minWidth": 800,
      "minHeight": 560
    },
    "extraPathPrefixes": {
      "darwin": [
        "/opt/homebrew/bin",
        "/opt/homebrew/sbin",
        "/usr/local/bin",
        "/usr/local/sbin"
      ],
      "linux": [
        "/usr/local/bin",
        "/usr/local/sbin",
        "${HOME}/.local/bin",
        "/snap/bin"
      ],
      "win32": [
        "${HOME}/scoop/shims",
        "${HOME}/.pyenv/pyenv-win/shims",
        "${HOME}/.pyenv/pyenv-win/bin",
        "${HOME}/AppData/Local/Microsoft/WindowsApps",
        "${HOME}/AppData/Local/Microsoft/WinGet/Packages",
        "C:/ProgramData/chocolatey/bin",
        "C:/Program Files/ffmpeg/bin"
      ]
    },
    "bundledPython": {
      "venvDirName": ".venv",
      "requirementsFile": "requirements.txt",
      "minPythonVersion": "3.10"
    },
    "knownPythonPaths": {
      "darwin": [
        "/opt/homebrew/bin/python3.11",
        "/opt/homebrew/bin/python3.12",
        "/opt/homebrew/bin/python3",
        "/usr/local/bin/python3.11",
        "/usr/local/bin/python3.12",
        "/usr/local/bin/python3",
        "/usr/bin/python3"
      ],
      "linux": [
        "/usr/bin/python3.11",
        "/usr/bin/python3.12",
        "/usr/bin/python3",
        "/usr/local/bin/python3"
      ],
      "win32": [
        "${HOME}/AppData/Local/Programs/Python/Python314/python.exe",
        "${HOME}/AppData/Local/Programs/Python/Python313/python.exe",
        "${HOME}/AppData/Local/Programs/Python/Python312/python.exe",
        "${HOME}/AppData/Local/Programs/Python/Python311/python.exe",
        "${HOME}/AppData/Local/Programs/Python/Python310/python.exe",
        "${HOME}/AppData/Local/Microsoft/WindowsApps/python.exe",
        "${HOME}/AppData/Local/Microsoft/WindowsApps/python3.exe",
        "C:/Program Files/Python314/python.exe",
        "C:/Program Files/Python313/python.exe",
        "C:/Program Files/Python312/python.exe",
        "C:/Program Files/Python311/python.exe",
        "C:/Program Files/Python310/python.exe",
        "C:/Python314/python.exe",
        "C:/Python313/python.exe",
        "C:/Python312/python.exe",
        "C:/Python311/python.exe",
        "C:/Python310/python.exe",
        "C:/Windows/py.exe"
      ]
    }
  },
  "media": {
    "supportedMediaExtensions": [".mp4", ".mov", ".mkv", ".avi", ".ts", ".mjpeg", ".mpeg", ".f4v", ".flv", ".m2t", ".m2ts", ".m2v", ".3gp", ".3g2", ".mp3", ".wav", ".ogg", ".flac", ".m4a", ".m4v", ".aiff"],
    "subtitleExtensions": [".srt", ".vtt", ".ass", ".ssa"]
  }
}
