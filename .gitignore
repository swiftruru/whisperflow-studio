node_modules/
dist/
# Anchored to project root so only the portable dev override is
# ignored — NOT the translation files locales/*/settings.json, which
# must be tracked so CI builds ship the Settings-tab i18n strings.
/settings.json
python/config/config.json
# User-created config profiles (profile-switcher.js creates each as a
# subdirectory of python/config/ containing its own config.json).
python/config/*/
test.mjs

# Claude Code local session state (permissions, memory, plans).
# Machine-local, must never be committed.
.claude/

# ── Python ─────────────────────────────────────────────────────────────────
# Bundled virtualenvs (created on first launch via venv-installer.js).
# These are machine-local and ~2 GB each — must never be committed.
python/.venv/
python/.venv-test/
.venv/
.venv-test/

# Byte-compiled / optimised / test caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# setuptools / pip build artefacts
python/*.egg-info/
python/build/
python/dist/

# ── Vendored upstream (removed in v1.4.0, keep the ignore as a safety net) ─
_faster-whisper-webui/
